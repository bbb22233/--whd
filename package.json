{
  "name": "quant-monitor-terminal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "node server.mjs",
    "download": "uv run python -m backend_py.run_data_pipeline --download-only --days 3650",
    "multi:1d": "uv run python -m backend_py.run_full_pipeline --skip-download --official --days 3650 --bars \"1D\"",
    "multi:weather": "uv run python -m backend_py.run_full_pipeline --skip-download --official --days 3650 --bars \"1D\"",
    "multi:summary": "uv run python -m backend_py.run_full_pipeline --from-reports --summary-only --skip-download --official --days 3650 --bars \"1D,4H,8H\"",
    "multi:periods": "uv run python -m backend_py.run_full_pipeline --skip-download --official --days 3650 --bars \"1D,4H,8H\"",
    "legacy:multi:1d": "node scripts/run-multi-symbol-1d.mjs",
    "legacy:multi:weather": "node scripts/run-multi-symbol-1d.mjs",
    "legacy:multi:periods": "node scripts/run-multi-symbol-1d.mjs --bars \"4H,8H,1D,1W\"",
    "download:macro": "node scripts/download-macro-data.mjs",
    "clean": "uv run python -m backend_py.run_data_pipeline --clean-only --days 3650",
    "legacy:download": "node scripts/download-data.mjs",
    "legacy:clean": "node scripts/clean-data.mjs",
    "backtest:indicators": "node scripts/backtest-indicators.mjs",
    "backtest:volatility": "node scripts/backtest-volatility-state.mjs",
    "backtest:position": "node scripts/backtest-position-state.mjs",
    "backtest:deviations": "node scripts/backtest-deviations.mjs",
    "rules:deviations": "uv run python -m backend_py.build_deviation_rules --official --days 3650",
    "weather:router": "uv run python -m backend_py.build_market_weather_router --official --days 3650",
    "backtest:router": "uv run python -m backend_py.backtest_strategy_router --official --days 3650",
    "calibrate:router": "uv run python -m backend_py.calibrate_router --official --days 3650",
    "features": "uv run python -m backend_py.build_feature_factory --official --days 3650",
    "legacy:rules:deviations": "node scripts/build-deviation-rules.mjs",
    "legacy:weather:router": "node scripts/build-market-weather-router.mjs",
    "legacy:features": "node scripts/build-feature-factory.mjs",
    "legacy:backtest:router": "node scripts/backtest-strategy-router.mjs",
    "legacy:calibrate:router": "node scripts/calibrate-router.mjs",
    "journal:create": "node scripts/create-decision-journal.mjs",
    "train:trees": "node scripts/train-decision-trees.mjs",
    "validate:trees": "node scripts/validate-decision-trees.mjs",
    "compare:macro": "node scripts/compare-macro-impact.mjs",
    "train:state": "node scripts/train-market-state.mjs"
  }
}
