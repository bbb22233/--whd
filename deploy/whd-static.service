# 前端静态服务(server.mjs)。放 /etc/systemd/system/whd-static.service
[Unit]
Description=WHD Market Weather static frontend (server.mjs)
After=network.target

[Service]
Type=simple
User=whd
WorkingDirectory=/srv/whd
# 仅绑 127.0.0.1,只让 Caddy 反代对外
Environment=HOST=127.0.0.1
Environment=PORT=4177
ExecStart=/usr/bin/env node server.mjs
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
